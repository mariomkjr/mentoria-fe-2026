---
interface Props {
  number: number;
  title: string;
}

const { number, title } = Astro.props;
---

<section class="content-section section-spacing" id={`secao-${number}`}>
  <div class="container max-w-3xl">
    <header class="text-center mb-8">
      <span class="inline-block px-4 py-1 bg-gold/20 text-gold-dark rounded-full text-sm font-semibold mb-3">
        {number.toString().padStart(2, '0')}
      </span>
      <h2 class="text-bordo">{title}</h2>
      <div class="gold-divider"></div>
    </header>

    <div class="prose prose-lg max-w-none text-ink/90">
      <slot />
    </div>
  </div>
</section>
