---
import AdSlot from './AdSlot.astro';

interface Props {
  id: string;
  eager?: boolean;
  class?: string;
}

const { id, eager = false, class: className = '' } = Astro.props;
---

<div class:list={['ad-display-banner', className]}>
  <AdSlot id={id} eager={eager} />
</div>

<style>
  .ad-display-banner {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }
</style>
