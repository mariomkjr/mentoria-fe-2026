---
import slotsData from '~/data/ad-slots.json';

interface Props {
  id: string;
  class?: string;
  eager?: boolean;
}

const { id, class: className = '', eager = false } = Astro.props;
const slot = (slotsData as any).slots[id];

function pickCreative(creatives: any[]) {
  if (!creatives || creatives.length === 0) return null;
  const now = new Date();
  const active = creatives.filter((c) => {
    if (c.active === false) return false;
    if (c.start_at && new Date(c.start_at) > now) return false;
    if (c.end_at && new Date(c.end_at) < now) return false;
    return true;
  });
  if (active.length === 0) return null;
  const totalWeight = active.reduce((s, c) => s + (c.weight || 1), 0);
  let r = Math.random() * totalWeight;
  for (const c of active) {
    r -= (c.weight || 1);
    if (r <= 0) return c;
  }
  return active[0];
}

const creative = slot ? pickCreative(slot.creatives) : null;
const dims = slot?.dimensions || { width: 728, height: 90 };
const mobileDims = slot?.mobileDimensions || dims;
const aspect = `${dims.width} / ${dims.height}`;
const aspectMobile = `${mobileDims.width} / ${mobileDims.height}`;
---

{slot && creative ? (
  <aside
    class:list={['ad-display-slot', `ad-display-slot--${id}`, className]}
    data-ad-slot-id={id}
    data-ad-advertiser={creative.advertiser}
    role="complementary"
  >
    <a
      href={creative.href}
      target="_blank"
      rel="sponsored noopener noreferrer"
      class="ad-display-slot__link"
      data-ad-click
    >
      <picture>
        {creative.imageMobile && (
          <source media="(max-width: 767px)" srcset={creative.imageMobile} />
        )}
        <img
          src={creative.image}
          alt={creative.alt || ''}
          width={dims.width}
          height={dims.height}
          loading={eager ? 'eager' : 'lazy'}
          decoding={eager ? 'sync' : 'async'}
          class="ad-display-slot__image"
        />
      </picture>
    </a>
  </aside>
) : slot ? (
  <aside
    class:list={['ad-display-slot ad-display-slot--empty', className]}
    data-ad-slot-id={id}
    aria-hidden="true"
  ></aside>
) : null}

<style define:vars={{
  slotW: `${dims.width}px`,
  slotH: `${dims.height}px`,
  aspect: aspect,
  aspectMobile: aspectMobile,
}}>
  .ad-display-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 1rem auto;
    width: 100%;
    max-width: var(--slotW);
    box-sizing: border-box;
  }
  @media (min-width: 768px) {
    .ad-display-slot { margin: 1.75rem auto; }
  }
  .ad-display-slot--empty {
    aspect-ratio: var(--aspect);
    background: rgb(245 240 230 / 0.4);
    border-radius: 6px;
    opacity: 0.3;
  }
  .ad-display-slot__link {
    display: block;
    line-height: 0;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }
  .ad-display-slot__image {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }
  @media (max-width: 767px) {
    .ad-display-slot {
      max-width: 100%;
      padding: 0 0.5rem;
    }
    .ad-display-slot--empty {
      aspect-ratio: var(--aspectMobile);
    }
  }
</style>

<script>
  function trackAdEvent(event: string, slot: string, advertiser: string) {
    if (typeof window === 'undefined') return;
    const w = window as any;
    if (w.plausible) { w.plausible('ad-' + event, { props: { slot, advertiser } }); return; }
    if (w.gtag) { w.gtag('event', 'ad_' + event, { slot, advertiser }); return; }
    if (!w.__ad_log) w.__ad_log = [];
    w.__ad_log.push({ event, slot, advertiser, ts: Date.now() });
  }

  document.querySelectorAll('[data-ad-slot-id]').forEach((el) => {
    const slotId = el.getAttribute('data-ad-slot-id');
    const advertiser = el.getAttribute('data-ad-advertiser');
    if (!slotId || !advertiser) return;

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            trackAdEvent('impression', slotId, advertiser);
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.5 });
      io.observe(el);
    }

    const link = el.querySelector('a[data-ad-click]');
    link?.addEventListener('click', () => trackAdEvent('click', slotId, advertiser));
  });
</script>
