---
interface Props {
  name: string;
  thumb: string;
  url: string;
  cta?: string;
  description?: string;
  rating?: number;
  reviewCount?: number;
  guarantee?: string;
  shipping?: string;
  recentSales?: string;
  badge?: string;
}

const {
  name,
  thumb,
  url,
  cta = 'QUERO COMEÇAR AGORA',
  description,
  rating = 4.8,
  reviewCount = 2847,
  guarantee = 'Garantia de 30 dias',
  shipping = 'Frete grátis para todo Brasil',
  recentSales,
  badge,
} = Astro.props;

const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(rating));
---

<aside class="adv-cta">
  {badge && <div class="adv-cta__badge">{badge}</div>}
  <a href={url} target="_blank" rel="sponsored noopener noreferrer" class="adv-cta__link" data-adv-cta>
    <div class="adv-cta__thumb">
      <img src={thumb} alt={name} loading="lazy" decoding="async" />
    </div>
    <div class="adv-cta__body">
      <h3 class="adv-cta__title">{name}</h3>
      <div class="adv-cta__rating">
        <span class="adv-cta__stars" aria-label={`Avaliação ${rating} de 5`}>
          {stars.map((on) => (
            <svg viewBox="0 0 24 24" class:list={[on && 'on']} aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
            </svg>
          ))}
        </span>
        <strong>{rating.toFixed(1)}</strong>
        <span class="adv-cta__rev">({reviewCount.toLocaleString('pt-BR')} avaliações)</span>
      </div>
      {description && <p class="adv-cta__desc">{description}</p>}
      <ul class="adv-cta__trust">
        <li>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
          <span>{guarantee}</span>
        </li>
        <li>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20 8h-3V6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v9c0 1.1.9 2 2 2 0 1.66 1.34 3 3 3s3-1.34 3-3h4c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-2-4zM7 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm12 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm-2-4.5h-2.5l-2-3H17v3z"/></svg>
          <span>{shipping}</span>
        </li>
        <li>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <span>Compra 100% segura</span>
        </li>
      </ul>
      <span class="adv-cta__btn">{cta} <span aria-hidden="true">→</span></span>
      {recentSales && (
        <p class="adv-cta__recent">
          <span class="adv-cta__pulse" aria-hidden="true"></span>
          {recentSales}
        </p>
      )}
    </div>
  </a>
</aside>

<style>
  .adv-cta {
    position: relative;
    margin: 2.25rem 0;
  }
  .adv-cta__badge {
    position: absolute;
    top: -10px;
    left: 22px;
    background: rgb(220 38 38);
    color: white;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    text-transform: uppercase;
    z-index: 2;
    box-shadow: 0 4px 12px rgb(220 38 38 / 0.3);
  }
  .adv-cta__link {
    display: flex;
    flex-direction: column;
    background: white;
    border: 2px solid rgb(201 162 75 / 0.35);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none !important;
    color: inherit;
    transition: all 0.25s;
    box-shadow: 0 6px 24px rgb(122 31 58 / 0.1);
  }
  .adv-cta__link:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgb(122 31 58 / 0.22);
    border-color: rgb(201 162 75);
  }
  .adv-cta__thumb {
    background: linear-gradient(135deg, rgb(245 240 230), white);
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .adv-cta__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 1rem;
  }
  .adv-cta__body { padding: 1.5rem 1.6rem 1.75rem; }

  .adv-cta__title {
    font-family: var(--aw-font-heading, 'Playfair Display', Georgia, serif);
    font-weight: 700;
    color: rgb(122 31 58);
    font-size: 1.4rem;
    line-height: 1.18;
    margin: 0 0 0.65rem;
  }

  .adv-cta__rating {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
    font-size: 0.88rem;
    color: rgb(30 28 32 / 0.75);
  }
  .adv-cta__stars {
    display: inline-flex;
    gap: 1px;
    color: rgb(201 162 75 / 0.3);
  }
  .adv-cta__stars svg { width: 16px; height: 16px; }
  .adv-cta__stars .on { color: rgb(201 162 75); }
  .adv-cta__rating strong { color: rgb(11 11 15); font-weight: 700; }
  .adv-cta__rev { color: rgb(30 28 32 / 0.6); }

  .adv-cta__desc {
    color: rgb(30 28 32 / 0.78);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0 0 1.1rem;
  }

  .adv-cta__trust {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0.85rem 1rem;
    background: rgb(245 240 230 / 0.7);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .adv-cta__trust li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.86rem;
    color: rgb(30 28 32 / 0.85);
    font-weight: 500;
  }
  .adv-cta__trust svg {
    width: 16px;
    height: 16px;
    color: rgb(15 130 80);
    flex-shrink: 0;
  }

  .adv-cta__btn {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, rgb(122 31 58), rgb(154 58 84));
    color: white;
    text-align: center;
    padding: 1rem 1.5rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.04em;
    box-shadow: 0 6px 20px rgb(122 31 58 / 0.3);
    transition: all 0.2s;
  }
  .adv-cta__link:hover .adv-cta__btn {
    background: linear-gradient(135deg, rgb(92 23 41), rgb(122 31 58));
    box-shadow: 0 8px 24px rgb(122 31 58 / 0.45);
  }
  .adv-cta__btn span { margin-left: 0.4rem; }

  .adv-cta__recent {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0.85rem 0 0;
    font-size: 0.82rem;
    color: rgb(15 130 80);
    font-weight: 600;
    text-align: center;
  }
  .adv-cta__pulse {
    width: 8px;
    height: 8px;
    background: rgb(15 130 80);
    border-radius: 50%;
    animation: ctaPulse 1.6s infinite;
  }
  @keyframes ctaPulse {
    0% { box-shadow: 0 0 0 0 rgb(15 130 80 / 0.6); }
    70% { box-shadow: 0 0 0 8px rgb(15 130 80 / 0); }
    100% { box-shadow: 0 0 0 0 rgb(15 130 80 / 0); }
  }

  :global(.dark) .adv-cta__link {
    background: rgb(40 30 35);
    border-color: rgb(221 184 101 / 0.3);
  }
  :global(.dark) .adv-cta__link:hover { border-color: rgb(221 184 101); }
  :global(.dark) .adv-cta__thumb { background: linear-gradient(135deg, rgb(40 30 35), rgb(50 35 40)); }
  :global(.dark) .adv-cta__title { color: rgb(221 184 101); }
  :global(.dark) .adv-cta__rating { color: rgb(229 222 206 / 0.75); }
  :global(.dark) .adv-cta__rating strong { color: rgb(247 244 235); }
  :global(.dark) .adv-cta__rev { color: rgb(229 222 206 / 0.6); }
  :global(.dark) .adv-cta__desc { color: rgb(229 222 206 / 0.78); }
  :global(.dark) .adv-cta__trust {
    background: rgb(30 22 26 / 0.7);
  }
  :global(.dark) .adv-cta__trust li { color: rgb(229 222 206 / 0.88); }
  :global(.dark) .adv-cta__btn {
    background: linear-gradient(135deg, rgb(221 184 101), rgb(201 162 75));
    color: rgb(20 12 16);
  }
  :global(.dark) .adv-cta__link:hover .adv-cta__btn {
    background: linear-gradient(135deg, rgb(201 162 75), rgb(180 145 65));
  }

  @media (min-width: 720px) {
    .adv-cta__link { flex-direction: row; align-items: stretch; }
    .adv-cta__thumb {
      width: 280px;
      flex-shrink: 0;
      aspect-ratio: 1 / 1;
    }
    .adv-cta__body { flex: 1; padding: 1.75rem 2rem; }
  }
</style>

<script>
  document.querySelectorAll('[data-adv-cta]').forEach((el) => {
    el.addEventListener('click', () => {
      const w = window as any;
      if (w.plausible) w.plausible('adv-cta-click', { props: { url: (el as HTMLAnchorElement).href }});
      else if (w.gtag) w.gtag('event', 'adv_cta_click', { url: (el as HTMLAnchorElement).href });
    });
  });
</script>
