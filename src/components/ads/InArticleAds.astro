---
interface Props {
  interval?: number;
  slotIds?: string[];
}

const { interval = 3, slotIds = [] } = Astro.props;
const slotsJson = slotIds.length > 0 ? JSON.stringify(slotIds) : '[]';
---

<div class="in-article-ads-wrap" data-in-article-ads data-interval={interval} data-slot-ids={slotsJson}>
  <slot />
</div>

<script>
  import slotsData from '~/data/ad-slots.json';

  const wraps = document.querySelectorAll('[data-in-article-ads]');
  wraps.forEach((wrap) => {
    const interval = parseInt(wrap.getAttribute('data-interval') || '3', 10);
    const slotIds: string[] = JSON.parse(wrap.getAttribute('data-slot-ids') || '[]');
    if (slotIds.length === 0) return;

    const paragraphs = Array.from(wrap.querySelectorAll(':scope > p'));
    let slotIdx = 0;
    paragraphs.forEach((p, i) => {
      if ((i + 1) % interval === 0 && slotIdx < slotIds.length) {
        const slotId = slotIds[slotIdx++];
        const slot = (slotsData as any).slots[slotId];
        if (!slot) return;
        const now = new Date();
        const active = (slot.creatives || []).filter((c: any) => {
          if (c.active === false) return false;
          if (c.start_at && new Date(c.start_at) > now) return false;
          if (c.end_at && new Date(c.end_at) < now) return false;
          return true;
        });
        const dims = slot.dimensions || { width: 728, height: 90 };
        const container = document.createElement('div');
        container.style.margin = '2rem 0';
        container.style.minHeight = dims.height + 40 + 'px';

        if (active.length === 0) {
          const empty = document.createElement('aside');
          empty.className = 'ad-display-slot ad-display-slot--empty';
          empty.style.cssText = `margin:0 auto;width:100%;max-width:${dims.width}px;aspect-ratio:${dims.width} / ${dims.height};background:rgb(245 240 230 / 0.4);border-radius:6px;opacity:0.3;`;
          empty.setAttribute('aria-hidden', 'true');
          container.appendChild(empty);
        } else {
          const totalWeight = active.reduce((s: number, c: any) => s + (c.weight || 1), 0);
          let r = Math.random() * totalWeight;
          let creative = active[0];
          for (const c of active) {
            r -= (c.weight || 1);
            if (r <= 0) { creative = c; break; }
          }
          // Defesa: só http(s) — bloqueia javascript:, data:, vbscript:
          const safeHref = /^https?:\/\//i.test(creative.href || '') ? creative.href : '#';
          const safeImage = /^https?:\/\/|^\//.test(creative.image || '') ? creative.image : '';

          const aside = document.createElement('aside');
          aside.className = `ad-display-slot ad-display-slot--${String(slotId).replace(/[^a-z0-9-_]/gi, '')}`;
          aside.setAttribute('data-ad-slot-id', slotId);
          aside.setAttribute('data-ad-advertiser', creative.advertiser || '');
          aside.style.cssText = `margin:1.5rem auto;width:100%;max-width:${dims.width}px;text-align:center;`;

          const a = document.createElement('a');
          a.href = safeHref;
          a.target = '_blank';
          a.rel = 'sponsored noopener noreferrer';
          a.setAttribute('data-ad-click', '');
          a.style.cssText = 'display:block;line-height:0;border-radius:8px;overflow:hidden;width:100%;';

          const img = document.createElement('img');
          img.src = safeImage;
          img.alt = creative.alt || '';
          img.width = dims.width;
          img.height = dims.height;
          img.loading = 'lazy';
          img.decoding = 'async';
          img.style.cssText = 'width:100%;height:auto;display:block;';

          a.appendChild(img);
          aside.appendChild(a);
          container.appendChild(aside);
          trackImpressionAndClick(container, slotId, creative.advertiser);
        }
        p.after(container);
      }
    });
  });

  function trackAdEvent(event: string, slot: string, advertiser: string) {
    const w = window as any;
    if (w.plausible) return w.plausible('ad-' + event, { props: { slot, advertiser } });
    if (w.gtag) return w.gtag('event', 'ad_' + event, { slot, advertiser });
    if (!w.__ad_log) w.__ad_log = [];
    w.__ad_log.push({ event, slot, advertiser, ts: Date.now() });
  }

  function trackImpressionAndClick(el: HTMLElement, slotId: string, advertiser: string) {
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            trackAdEvent('impression', slotId, advertiser);
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.5 });
      io.observe(el);
    }
    const link = el.querySelector('a[data-ad-click]');
    link?.addEventListener('click', () => trackAdEvent('click', slotId, advertiser));
  }
</script>
