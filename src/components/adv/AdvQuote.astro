---
interface Props {
  cite?: string;
}
const { cite } = Astro.props;
---

<blockquote class="adv-quote">
  <svg class="adv-quote__mark" viewBox="0 0 32 32" aria-hidden="true">
    <path d="M9.5 8c-3 0-5.5 2.5-5.5 5.5v8c0 1.7 1.3 3 3 3h5c1.7 0 3-1.3 3-3v-5c0-1.7-1.3-3-3-3H8c0-1.7 1.3-3 3-3 .8 0 1.5-.7 1.5-1.5S11.8 6.5 11 6.5c-.5 0-1 .5-1.5 1.5zm14 0c-3 0-5.5 2.5-5.5 5.5v8c0 1.7 1.3 3 3 3h5c1.7 0 3-1.3 3-3v-5c0-1.7-1.3-3-3-3H22c0-1.7 1.3-3 3-3 .8 0 1.5-.7 1.5-1.5S25.8 6.5 25 6.5c-.5 0-1 .5-1.5 1.5z" fill="currentColor"/>
  </svg>
  <div class="adv-quote__body"><slot /></div>
  {cite && <cite class="adv-quote__cite">— {cite}</cite>}
</blockquote>

<style>
  .adv-quote {
    position: relative;
    margin: 2.25rem 0;
    padding: 1.75rem 2rem 1.75rem 3.5rem;
    border-left: 4px solid rgb(201 162 75);
    background: linear-gradient(135deg, rgb(122 31 58 / 0.04), rgb(201 162 75 / 0.06));
    border-radius: 0 12px 12px 0;
    font-family: var(--aw-font-heading, 'Playfair Display', Georgia, serif);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.5;
    color: rgb(30 28 32);
  }
  .adv-quote__mark {
    position: absolute;
    top: 1.2rem;
    left: 1.1rem;
    width: 26px;
    height: 26px;
    color: rgb(201 162 75);
    opacity: 0.7;
  }
  .adv-quote__body :global(p) {
    margin: 0 0 0.5rem;
  }
  .adv-quote__body :global(p:last-child) { margin-bottom: 0; }
  .adv-quote__cite {
    display: block;
    margin-top: 0.85rem;
    font-family: var(--aw-font-sans, 'Inter', sans-serif);
    font-style: normal;
    font-size: 0.92rem;
    font-weight: 600;
    color: rgb(122 31 58);
    letter-spacing: 0.02em;
  }
  :global(.dark) .adv-quote {
    color: rgb(229 222 206);
    background: linear-gradient(135deg, rgb(154 58 84 / 0.12), rgb(221 184 101 / 0.08));
    border-color: rgb(221 184 101);
  }
  :global(.dark) .adv-quote__mark { color: rgb(221 184 101); }
  :global(.dark) .adv-quote__cite { color: rgb(221 184 101); }
</style>
