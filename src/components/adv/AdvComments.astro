---
interface Comment {
  name: string;
  city?: string;
  text: string;
  ago?: string;
  likes?: number;
  replies?: number;
}
interface Props {
  title?: string;
  count?: number;
  comments: Comment[];
}
const {
  title = 'Comentários',
  count,
  comments,
} = Astro.props;

const palette = ['#7A1F3A', '#C9A24B', '#5C1729', '#9A3A54', '#1E3A8A', '#064E3B', '#4C1D95', '#831843', '#7C2D12'];
function avatar(name) {
  const idx = name.split('').reduce((a, c) => a + c.charCodeAt(0), 0) % palette.length;
  return { color: palette[idx], initial: name.trim().charAt(0).toUpperCase() };
}
---

<section class="adv-cm">
  <header class="adv-cm__head">
    <h3>{title}</h3>
    <span class="adv-cm__count">{count ?? comments.length} comentários</span>
  </header>
  <ul class="adv-cm__list">
    {comments.map((c) => {
      const a = avatar(c.name);
      return (
        <li class="adv-cm__item">
          <div class="adv-cm__avatar" style={`background:${a.color}`}>{a.initial}</div>
          <div class="adv-cm__body">
            <div class="adv-cm__name">
              <strong>{c.name}</strong>
              {c.city && <span> · {c.city}</span>}
              <span class="adv-cm__ago"> · {c.ago || 'há algumas horas'}</span>
            </div>
            <p class="adv-cm__text">{c.text}</p>
            <div class="adv-cm__actions">
              <button type="button" class="adv-cm__btn">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M2 9h4v12H2zM23 10c0-1.1-.9-2-2-2h-6.31l.95-4.57c.02-.1.03-.21.03-.32 0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-1.91z"/></svg>
                Curtir <span>· {c.likes ?? Math.floor(Math.random() * 80 + 10)}</span>
              </button>
              <button type="button" class="adv-cm__btn">Responder · {c.replies ?? Math.floor(Math.random() * 6 + 1)}</button>
            </div>
          </div>
        </li>
      );
    })}
  </ul>
  <button type="button" class="adv-cm__more">Ver mais comentários</button>
</section>

<style>
  .adv-cm {
    margin: 2.5rem 0;
    padding: 1.75rem;
    border: 1px solid rgb(201 162 75 / 0.3);
    border-radius: 14px;
    background: rgb(253 251 245);
  }
  .adv-cm__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgb(201 162 75 / 0.3);
  }
  .adv-cm__head h3 {
    font-family: var(--aw-font-heading, 'Playfair Display', Georgia, serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: rgb(11 11 15);
    margin: 0;
  }
  .adv-cm__count {
    font-size: 0.82rem;
    color: rgb(30 28 32 / 0.6);
  }
  .adv-cm__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .adv-cm__item {
    display: flex;
    gap: 0.85rem;
  }
  .adv-cm__avatar {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    border-radius: 50%;
    color: white;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--aw-font-heading, 'Playfair Display', Georgia, serif);
  }
  .adv-cm__body { flex: 1; min-width: 0; }
  .adv-cm__name {
    font-size: 0.88rem;
    color: rgb(30 28 32 / 0.7);
    margin-bottom: 0.25rem;
  }
  .adv-cm__name strong { color: rgb(11 11 15); font-weight: 600; }
  .adv-cm__ago { color: rgb(30 28 32 / 0.55); }
  .adv-cm__text {
    font-size: 0.96rem;
    line-height: 1.5;
    color: rgb(30 28 32 / 0.92);
    margin: 0 0 0.55rem;
  }
  .adv-cm__actions {
    display: flex;
    gap: 1.25rem;
  }
  .adv-cm__btn {
    background: none;
    border: none;
    color: rgb(122 31 58);
    font-size: 0.83rem;
    font-weight: 600;
    padding: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .adv-cm__btn svg { width: 14px; height: 14px; }
  .adv-cm__btn span { color: rgb(30 28 32 / 0.55); font-weight: 500; margin-left: 4px; }
  .adv-cm__btn:hover { text-decoration: underline; }
  .adv-cm__more {
    margin-top: 1.25rem;
    width: 100%;
    padding: 0.75rem;
    background: none;
    border: 1px solid rgb(201 162 75 / 0.4);
    border-radius: 10px;
    color: rgb(122 31 58);
    font-weight: 600;
    cursor: pointer;
    font-size: 0.92rem;
  }
  .adv-cm__more:hover {
    background: rgb(122 31 58 / 0.05);
  }
  :global(.dark) .adv-cm {
    background: rgb(40 30 35 / 0.5);
    border-color: rgb(221 184 101 / 0.25);
  }
  :global(.dark) .adv-cm__head { border-color: rgb(221 184 101 / 0.25); }
  :global(.dark) .adv-cm__head h3 { color: rgb(247 244 235); }
  :global(.dark) .adv-cm__count { color: rgb(229 222 206 / 0.6); }
  :global(.dark) .adv-cm__name { color: rgb(229 222 206 / 0.7); }
  :global(.dark) .adv-cm__name strong { color: rgb(247 244 235); }
  :global(.dark) .adv-cm__ago { color: rgb(229 222 206 / 0.55); }
  :global(.dark) .adv-cm__text { color: rgb(229 222 206 / 0.92); }
  :global(.dark) .adv-cm__btn { color: rgb(221 184 101); }
  :global(.dark) .adv-cm__btn span { color: rgb(229 222 206 / 0.55); }
  :global(.dark) .adv-cm__more {
    color: rgb(221 184 101);
    border-color: rgb(221 184 101 / 0.4);
  }
  :global(.dark) .adv-cm__more:hover { background: rgb(221 184 101 / 0.08); }
</style>
