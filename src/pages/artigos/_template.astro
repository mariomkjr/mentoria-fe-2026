---
/**
 * TEMPLATE para artigos individuais
 *
 * INSTRUÇÕES PARA CLEO:
 *
 * 1. Copie este arquivo para: src/pages/artigos/[slug].astro
 *    Exemplo: src/pages/artigos/poder-da-oracao.astro
 *
 * 2. Preencha as variáveis abaixo:
 *    - title: título do artigo
 *    - description: meta description (150-160 chars)
 *    - author: "Pr. Elias Martins" ou outro
 *    - publishDate: data de publicação
 *    - readingTime: tempo estimado de leitura
 *
 * 3. Preencha o array `sections` com as seções do artigo:
 *    Cada seção pode ter:
 *    - title: título da seção
 *    - verse: { text: "versículo", ref: "Livro 1:1" } (opcional)
 *    - body: array de parágrafos (strings)
 *
 * 4. O layout já está preparado para anúncios nativos a cada 3 seções
 */

import Layout from '~/layouts/PageLayout.astro';
import NativeAdSlot from '~/components/NativeAdSlot.astro';

const metadata = {
  title: 'TÍTULO DO ARTIGO AQUI',
  description: 'Meta description curta aqui (150-160 caracteres)',
};

const author = 'Pr. Elias Martins';
const publishDate = '21 de abril de 2026';
const readingTime = '8 min de leitura';

// Estrutura de conteúdo
const sections = [
  {
    n: 1,
    title: 'Título da Primeira Seção',
    verse: {
      text: 'Versículo completo aqui se aplicável',
      ref: 'João 3:16'
    },
    body: [
      'Primeiro parágrafo da seção. Texto devocional aqui.',
      'Segundo parágrafo se necessário.',
    ]
  },
  {
    n: 2,
    title: 'Título da Segunda Seção',
    body: [
      'Parágrafo único ou múltiplos conforme necessário.',
    ]
  },
  // ... adicione mais seções conforme necessário
];

const closingParagraph = 'Parágrafo de encerramento final do artigo (opcional).';
---

<Layout metadata={metadata}>
  <article class="max-w-4xl mx-auto px-4 py-12 md:py-16">

    <!-- Header do artigo -->
    <header class="mb-10 md:mb-14 border-b border-accent/20 pb-8">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-primary leading-tight mb-4">
        {metadata.title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
        <span class="font-semibold text-primary">Por {author}</span>
        <span>·</span>
        <time datetime={publishDate}>{publishDate}</time>
        <span>·</span>
        <span>{readingTime}</span>
      </div>
    </header>

    <!-- Conteúdo do artigo -->
    <div class="prose prose-lg max-w-none">
      {sections.map((section, index) => (
        <section id={`secao-${section.n}`} class="mb-12 scroll-mt-24">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary mb-4">
            {section.title}
          </h2>

          {section.verse && (
            <blockquote class="border-l-4 border-accent pl-6 py-4 mb-6 bg-gray-50/50 rounded-r-lg">
              <p class="text-lg italic text-gray-700 mb-2">"{section.verse.text}"</p>
              <cite class="text-sm font-semibold text-accent not-italic">— {section.verse.ref}</cite>
            </blockquote>
          )}

          {section.body.map((paragraph) => (
            <p class="text-base md:text-lg leading-relaxed text-gray-800 mb-4" set:html={paragraph} />
          ))}
        </section>

        {/* Anúncio nativo a cada 3 seções */}
        {(index + 1) % 3 === 0 && index < sections.length - 1 && (
          <div class="my-12">
            <NativeAdSlot variant="in-article" />
          </div>
        )}
      ))}

      {/* Parágrafo de encerramento */}
      {closingParagraph && (
        <div class="mt-12 pt-8 border-t border-accent/20">
          <p class="text-lg leading-relaxed text-gray-800 italic">
            {closingParagraph}
          </p>
        </div>
      )}
    </div>

    <!-- Footer do artigo -->
    <footer class="mt-16 pt-8 border-t border-accent/20">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <p class="text-sm text-gray-600 mb-2">Gostou deste conteúdo? Compartilhe:</p>
          <div class="flex gap-3">
            <a href="#" class="text-primary hover:text-secondary transition-colors" aria-label="Compartilhar no WhatsApp">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </a>
            <a href="#" class="text-primary hover:text-secondary transition-colors" aria-label="Compartilhar no Facebook">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>
        <a href="/" class="text-sm font-semibold text-primary hover:text-secondary transition-colors">
          ← Voltar ao início
        </a>
      </div>
    </footer>

  </article>
</Layout>
