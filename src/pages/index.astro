<Layout metadata={metadata}>
  <article class="relative mx-auto max-w-[1140px] px-4 sm:px-6 lg:px-8 pt-8 md:pt-12 pb-16">
    <!-- Kicker -->
    <div class="text-center mb-4">
      <span class="inline-block px-3 py-1 bg-primary/10 text-primary font-semibold text-[11px] md:text-xs uppercase tracking-widest rounded-full">Devocional · Oração</span>
