---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import { YouTube } from 'astro-embed';

const metadata = {
  title: 'Mentoria Fé | Relacionamento Abençoado Segundo a Palavra',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero ================================================ -->
  <Hero
    id="hero"
    tagline="Mentoria bíblica para casais"
    actions={[
      { variant: 'primary', text: 'Quero Começar Agora', href: '#cta', icon: 'tabler:heart' },
      { text: 'Assistir o vídeo', href: '#video' },
    ]}
  >
    <Fragment slot="title">
      Um relacionamento <span class="text-accent">abençoado</span> segundo a Palavra de Deus
    </Fragment>

    <Fragment slot="subtitle">
      Descubra os <strong>3 pilares bíblicos</strong> que transformam casamentos — mesmo quando tudo parece perdido. Uma jornada de 20 ensinos fundamentados nas Escrituras para você edificar sua casa sobre a rocha.
    </Fragment>
  </Hero>

  <!-- Banner 1 (topo) ===================================== -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 -mt-10 mb-8">
    <a href="#cta" class="block group" aria-label="Oferta especial Mentoria Fé">
      <img
        src="/banners/banner-01.svg"
        alt="Mentoria Fé — Transforme seu relacionamento"
        width="1140"
        height="140"
        class="w-full h-auto rounded-xl shadow-lg transition-transform duration-300 group-hover:scale-[1.01]"
        loading="eager"
        decoding="async"
      />
    </a>
  </div>

  <!-- Video Section ========================================= -->
  <section id="video" class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="text-center mb-8">
      <p class="text-base text-secondary font-bold tracking-wide uppercase mb-2">Assista agora</p>
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-3">A mensagem que pode mudar seu lar</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">3 minutos que podem transformar a forma como você enxerga seu relacionamento.</p>
    </div>
    <div class="rounded-2xl overflow-hidden shadow-2xl border-2 border-accent/20">
      <YouTube id="hFZFjoX2cGg" title="Mentoria Fé — Mensagem Completa" poster="default" />
    </div>
  </section>

  <!-- Sobre =============================================== -->
  <Content
    id="sobre"
    tagline="Sobre a Mentoria"
    title="Por que sua casa precisa ser edificada sobre a rocha"
    items={[
      { title: 'Fundamento bíblico', description: 'Cada ensino é ancorado nas Escrituras — sem modismos, sem psicologia barata, apenas a Palavra viva.', icon: 'tabler:book' },
      { title: 'Linguagem do nosso tempo', description: 'Verdades eternas traduzidas para a realidade do casal moderno — sem jargões religiosos distantes.', icon: 'tabler:message' },
      { title: 'Aplicação imediata', description: 'Você não sai apenas inspirado — sai com ferramentas práticas para aplicar hoje mesmo no seu lar.', icon: 'tabler:target' },
    ]}
  >
    <Fragment slot="content">
      <p class="text-lg mb-4">
        Muitos casais cristãos constroem suas casas sobre a areia das emoções. Quando as tempestades vêm — e elas sempre vêm — tudo desmorona.
      </p>
      <p class="text-lg">
        <strong>A Mentoria Fé</strong> foi criada para você que deseja edificar sobre a rocha. São 20 ensinos progressivos que percorrem desde os fundamentos até os desafios mais delicados do casamento cristão.
      </p>
    </Fragment>
  </Content>

  <!-- 3 Pilares =========================================== -->
  <Features
    id="pilares"
    tagline="Os 3 Pilares"
    title="Toda casa abençoada está sobre três pilares"
    subtitle="Sem essa fundação, o relacionamento oscila ao primeiro vento contrário. Com ela, você atravessa qualquer tempestade."
    columns={3}
    items={[
      {
        title: 'Aliança',
        description: 'Não é um contrato que se quebra quando conveniente. É um pacto sagrado diante de Deus, selado por um compromisso que transcende as circunstâncias.',
        icon: 'tabler:hearts',
      },
      {
        title: 'Comunicação',
        description: '"Falar a verdade em amor" (Efésios 4:15). Honestidade sem crueldade. Transparência sem manipulação. Escuta antes de reagir.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Comunhão',
        description: 'Um casal que ora junto, estuda a Palavra junto e serve junto desenvolve uma intimidade que vai muito além do físico.',
        icon: 'tabler:flower',
      },
    ]}
  />

  <!-- Stats =============================================== -->
  <Stats
    stats={[
      { title: 'Ensinos bíblicos', amount: '20' },
      { title: 'Casais impactados', amount: '+3.5k' },
      { title: 'Anos de estudo', amount: '12' },
      { title: 'Aprovação', amount: '98%' },
    ]}
  />

  <!-- Banner 2 (entre meio) =============================== -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <a href="#cta" class="block group" aria-label="Garanta sua vaga agora">
      <img
        src="/banners/banner-02.svg"
        alt="Mentoria Fé — Garanta sua vaga"
        width="1000"
        height="300"
        class="w-full h-auto rounded-xl shadow-xl transition-transform duration-300 group-hover:scale-[1.01]"
        loading="lazy"
        decoding="async"
      />
    </a>
  </div>

  <!-- 20 Ensinos (FAQs pattern) =========================== -->
  <FAQs
    id="ensinos"
    tagline="Os 20 ensinos"
    title="O caminho completo do relacionamento abençoado"
    subtitle="Cada módulo traz um ensino fundamentado nas Escrituras."
    columns={2}
    items={[
      { title: '1. O Fundamento Inabalável do Amor Bíblico', description: 'O amor verdadeiro não é um sentimento — é uma decisão fundamentada na Palavra. Mateus 7:24 nos ensina a edificar sobre a rocha.' },
      { title: '2. Por Que Seu Relacionamento Precisa de Propósito Divino', description: 'Deus projetou o casamento para refletir Seu amor pela Igreja. Sem esse propósito maior, tudo se torna centrado em si mesmo.' },
      { title: '3. Os 3 Pilares de um Relacionamento Abençoado', description: 'Aliança, Comunicação e Comunhão. Toda casa que prospera está fundamentada nestes três pilares essenciais.' },
      { title: '4. O Erro Fatal Que 87% dos Casais Cristãos Cometem', description: 'Negligenciam a intimidade emocional achando que espiritualidade é suficiente. Vivem como colegas de quarto piedosos.' },
      { title: '5. Como a Oração Transforma Conflitos em Conexão', description: 'É quase impossível continuar brigando com alguém enquanto você ora por ela. A oração amolece seu coração primeiro.' },
      { title: '6. O Poder do Perdão Que Liberta', description: '"Setenta vezes sete" (Mateus 18:22). No casamento, o perdão é oxigênio — sem ele, ressentimentos envenenam tudo.' },
      { title: '7. Linguagens do Amor: O Que a Bíblia Já Sabia', description: 'Antes de Gary Chapman popularizar, Paulo já instruía maridos a amar suas esposas "como Cristo amou a igreja".' },
      { title: '8. Intimidade Santa: Desfazendo Mitos Religiosos', description: 'Cantares de Salomão celebra explicitamente o prazer conjugal. A Bíblia é muito mais livre do que a teologia distorcida ensinou.' },
      { title: '9. Quando Seu Cônjuge Não Muda', description: 'E se Deus estiver usando seu cônjuge — exatamente como ele é — para transformar VOCÊ primeiro?' },
      { title: '10. O Papel do Homem Segundo o Coração de Deus', description: 'Ser cabeça não é ser chefe. Jesus redefiniu liderança lavando os pés dos discípulos. Liderar servindo.' },
      { title: '11. O Chamado da Mulher Virtuosa Para Hoje', description: 'Provérbios 31 não é lista de tarefas impossíveis. É retrato de uma mulher que vive com propósito e sabedoria.' },
      { title: '12. Criando Filhos em Meio ao Caos do Mundo', description: 'Como preparar a próxima geração quando os valores mudam tão rapidamente. Deuteronômio 6 como manual.' },
      { title: '13. Finanças no Casamento: A Causa #1 de Brigas', description: 'Transparência financeira como ato espiritual. Mordomia, ofertas, dívidas — princípios bíblicos aplicados.' },
      { title: '14. Quando o Passado Ameaça o Presente', description: 'Traumas, bagagens emocionais, histórias de dor. Como a cura de Cristo alcança as feridas mais profundas.' },
      { title: '15. Amizade no Casamento: O Segredo dos 50 Anos Juntos', description: 'Casais que envelhecem juntos são amigos antes de serem amantes. O que cultivar além do romance.' },
      { title: '16. Proteções Contra a Tentação', description: 'Práticas espirituais e estruturais para blindar seu casamento contra o que busca destruí-lo silenciosamente.' },
      { title: '17. Quando a Igreja Machuca Seu Casamento', description: 'Legalismos, julgamentos, conselhos ruins de líderes bem-intencionados. Como filtrar sem perder a fé.' },
      { title: '18. Reconstruindo Depois da Traição', description: 'É possível. É difícil. É sobrenatural. Como Deus restaura o que parecia irreparável.' },
      { title: '19. Deixando um Legado Para as Próximas Gerações', description: 'Seu casamento está formando a visão que seus filhos terão do amor de Deus. O que você está transmitindo?' },
      { title: '20. O Próximo Passo Para Seu Relacionamento', description: 'Conhecimento sem aplicação é orgulho. Os primeiros 7 dias depois da mentoria — o que fazer.' },
    ]}
  />

  <!-- Banner 3 ============================================ -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-12">
    <a href="#cta" class="block group" aria-label="Quero meu lugar agora">
      <img
        src="/banners/banner-03.svg"
        alt="Última chamada Mentoria Fé"
        width="800"
        height="280"
        class="w-full h-auto rounded-xl shadow-xl transition-transform duration-300 group-hover:scale-[1.01]"
        loading="lazy"
        decoding="async"
      />
    </a>
  </div>

  <!-- CTA Final =========================================== -->
  <CallToAction
    id="cta"
    actions={[
      {
        variant: 'primary',
        text: 'Quero Minha Vaga Agora',
        href: 'https://pay.hotmart.com/exemplo',
        icon: 'tabler:heart-handshake',
      },
    ]}
  >
    <Fragment slot="title">
      Edifique sua casa sobre <span class="text-accent">a rocha</span>
    </Fragment>

    <Fragment slot="subtitle">
      20 ensinos bíblicos que transformam a forma como você ama. Acesso imediato, garantia incondicional de 7 dias.
    </Fragment>
  </CallToAction>
</Layout>
